{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "isolatedDeclarations": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    // The core uses node's built-in crypto (randomUUID); load its ambient types.
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
