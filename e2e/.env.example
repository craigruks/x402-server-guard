# e2e live spike against Base Sepolia. Copy to .env and fill in.
# Testnet only. These keys hold faucet funds of ~zero value; do not reuse a
# mainnet key here.

# REQUIRED. The payer wallet. Fund it with test USDC from https://faucet.circle.com
# (Base Sepolia). No gas ETH is needed for the payment itself (EIP-3009 is gasless;
# the facilitator pays gas on settle).
BUYER_PRIVATE_KEY=0x

# The facilitator that verifies and settles.
#   - Keyless hosted (default, simplest): https://x402.org/facilitator
#   - Self-hosted (primary rig, see scripts/run-facilitator.md): http://localhost:8402
FACILITATOR_URL=https://x402.org/facilitator

# OPTIONAL. Where payments are sent. Defaults to the buyer's own address, so the
# spike pays itself test USDC and loses nothing. Override to a merchant address if
# you want a distinct recipient.
# PAY_TO_ADDRESS=0x

# OPTIONAL overrides. Defaults target Base Sepolia + Circle test USDC.
# NETWORK=eip155:84532
# ASSET_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# PRICE_ATOMIC=1000
